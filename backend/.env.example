# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Database (Supabase Postgres) ---
# Supabase dashboard -> Project Settings -> Database -> Connection string
# DATABASE_URL is the pooled/transaction connection string Prisma uses at runtime.
# DIRECT_URL is the direct connection string Prisma uses for migrations.
DATABASE_URL=
DIRECT_URL=

# --- Supabase Auth (server-side) ---
# Supabase dashboard -> Project Settings -> API
# SUPABASE_URL is the Project URL.
# SUPABASE_SERVICE_ROLE_KEY is the "service_role" secret key (NOT the anon/publishable key).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Salesforce Express LLM Gateway (internal) ---
# Only needed for AI quiz generation. Requires Salesforce internal access
# (DevBar) to obtain a personal key. If you don't have access, leave these
# blank — the rest of the app (login, uploads, browsing) still works; only
# "Generate quiz" will fail with a clear "LLM gateway is not configured" error.
LLM_GATEWAY_URL=
ENG_AI_MODEL_GW_KEY=

# --- Optional ---
# Port the Express API listens on. Defaults to 4000 if not set.
PORT=4000
