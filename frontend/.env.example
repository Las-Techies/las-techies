# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Supabase Auth (client-side) ---
# Supabase dashboard -> Project Settings -> API
# VITE_SUPABASE_URL is the Project URL (same project as the backend's SUPABASE_URL).
# VITE_SUPABASE_PUBLISHABLE_KEY is the "anon"/"publishable" key (NOT the service_role/secret key).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Backend API base URL ---
# Optional. Defaults to http://localhost:4000 if not set — only override this
# if your backend is running somewhere else (a different port, a deployed URL, etc.).
VITE_API_BASE_URL=
